/**
 * Lifecycle status for a SwatRequest.
 */
enum type RequestStatus {
  NEW = 'New'
  TRIAGING = 'Triaging'
  AWAITING_INFO = 'Awaiting Info'
  ACCEPTED = 'Accepted'
  SCOPING = 'Scoping'
  BUILDING = 'Building'
  SHIPPED = 'Shipped'
  DEFERRED = 'Deferred'
  ROUTED_ELSEWHERE = 'Routed Elsewhere'
  WONT_DO = "Won't Do"
}
