/**
 * Intake-side lifecycle status for a SwatRequest.
 * Build-side status lives on SwatSolution.
 */
enum type RequestStatus {
  TRIAGING = 'Triaging'
  ACCEPTED = 'Accepted'
  DEFERRED = 'Deferred'
  REJECTED = 'Rejected'
}
