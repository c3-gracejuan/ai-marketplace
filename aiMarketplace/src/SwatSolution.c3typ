entity type SwatSolution {
  title: !string
  problem: string
  solutionDescription: string
  hoursSaved: int
  dollarsSaved: int
  domain: [string]
  status: string enum SolutionStatus
  builders: [TeamMember]
  originatingRequests: [SwatRequest]
  dateShipped: datetime
  supportingMaterials: [SupportingMaterial](solution)
}
