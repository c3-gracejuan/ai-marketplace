entity type SwatSolution {
  title: !string
  problem: string
  solutionDescription: string
  impactSummary: string
  hoursSaved: int
  dollarsSaved: int
  domain: [string]
  stack: [string]
  solutionStatus: string
  builders: [TeamMember]
  requesterOrg: string
  dateShipped: datetime
  reusabilityNote: string
  featured: boolean
}
