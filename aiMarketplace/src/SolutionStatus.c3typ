/**
 * Build-side lifecycle status for a SwatSolution.
 * Queued solutions are auto-created when a SwatRequest is accepted.
 */
enum type SolutionStatus {
  QUEUED = 'Queued'
  BUILDING = 'Building'
  SHIPPED = 'Shipped'
}
